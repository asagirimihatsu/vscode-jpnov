# Allowlist strategy: ignore everything, then ship only the bundled ESM entries
# (client + server) and the metadata vsce needs. esbuild inlines all deps, so no
# node_modules ship.
**

!dist/client/extension.js
!dist/server/server.js
!package.json
!package.nls.json
!package.nls.ja.json
!l10n/**
!filelist.language-configuration.json
!jpnov.language-configuration.json
!syntaxes/**
!LICENSE
!README.md
