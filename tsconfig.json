{
  "compilerOptions": {
    "types": ["node", "vscode"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2025",
    "lib": ["ES2025"],

    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "test-fixtures/**/*.ts", "scripts/**/*.ts"],
  // The browser-context webview code is a separate program (DOM lib, no node/vscode) — see
  // src/client/webview/tsconfig.json. Its ambient env.d.ts must not leak `acquireVsCodeApi` into the host.
  "exclude": ["src/client/webview/**/*"]
}
