{
  "name": "jpnov",
  "displayName": "Japanese Novel",
  "publisher": "asagirimihatsu",
  "version": "0.1.0",
  "description": "VS Code を小説の執筆環境に変える拡張機能。書いた文章はすぐ隣に縦書きで表示され、章をまとめて HTML・PDF・テキストの本として出力できます。記法は青空文庫の注記そのまま。",
  "icon": "resources/icon.png",
  "keywords": [
    "小説",
    "縦書き",
    "青空文庫",
    "novel",
    "japanese",
    "aozora",
    "vertical writing"
  ],
  "homepage": "https://github.com/asagirimihatsu/vscode-jpnov#readme",
  "bugs": {
    "url": "https://github.com/asagirimihatsu/vscode-jpnov/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asagirimihatsu/vscode-jpnov.git"
  },
  "license": "MIT",
  "author": "Mihatsu Asagiri",
  "type": "module",
  "main": "dist/client/extension.js",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.129.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onWebviewPanel:jpnov.preview",
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jpnov",
        "aliases": [
          "%language.jpnov.alias%"
        ],
        "extensions": [
          ".jpnov"
        ],
        "configuration": "./jpnov.language-configuration.json"
      },
      {
        "id": "jpbook",
        "aliases": [
          "%language.jpbook.alias%"
        ],
        "extensions": [
          ".jpbook"
        ],
        "configuration": "./jpbook.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jpnov",
        "scopeName": "text.jpnov",
        "path": "./syntaxes/jpnov.tmLanguage.json"
      },
      {
        "language": "jpbook",
        "scopeName": "text.jpbook",
        "path": "./syntaxes/jpbook.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[jpnov]": {
        "editor.wordBasedSuggestions": "off",
        "editor.semanticHighlighting.enabled": true,
        "editor.unicodeHighlight.nonBasicASCII": false,
        "editor.unicodeHighlight.allowedCharacters": {
          "　": true,
          "！": true,
          "？": true,
          "（": true,
          "）": true,
          "：": true,
          "；": true,
          "，": true,
          "．": true,
          "｜": true,
          "＃": true,
          "［": true,
          "］": true,
          "〔": true,
          "〕": true,
          "〜": true,
          "～": true,
          "＊": true
        }
      },
      "[jpbook]": {
        "editor.wordBasedSuggestions": "off",
        "editor.unicodeHighlight.nonBasicASCII": false,
        "editor.unicodeHighlight.allowedCharacters": {
          "　": true,
          "！": true,
          "？": true,
          "（": true,
          "）": true,
          "：": true,
          "；": true,
          "，": true,
          "．": true,
          "｜": true,
          "＃": true,
          "［": true,
          "］": true,
          "〔": true,
          "〕": true,
          "〜": true,
          "～": true,
          "＊": true
        }
      },
      "github.copilot.enable": {
        "jpnov": false,
        "jpbook": false
      }
    },
    "configuration": [
      {
        "title": "%jpnov.layout.title%",
        "order": 1,
        "properties": {
          "jpnov.layout.charsPerLine": {
            "type": "integer",
            "default": 40,
            "minimum": 16,
            "maximum": 64,
            "order": 1,
            "markdownDescription": "%jpnov.layout.charsPerLine.description%"
          },
          "jpnov.layout.linesPerPage": {
            "type": "integer",
            "default": 34,
            "minimum": 16,
            "maximum": 64,
            "order": 2,
            "markdownDescription": "%jpnov.layout.linesPerPage.description%"
          },
          "jpnov.layout.kinsoku": {
            "type": "string",
            "enum": [
              "none",
              "normal",
              "strict"
            ],
            "default": "normal",
            "enumItemLabels": [
              "%jpnov.layout.kinsoku.none.label%",
              "%jpnov.layout.kinsoku.normal.label%",
              "%jpnov.layout.kinsoku.strict.label%"
            ],
            "enumDescriptions": [
              "%jpnov.layout.kinsoku.none.description%",
              "%jpnov.layout.kinsoku.normal.description%",
              "%jpnov.layout.kinsoku.strict.description%"
            ],
            "order": 3,
            "markdownDescription": "%jpnov.layout.kinsoku.description%"
          },
          "jpnov.layout.autoTcy": {
            "type": "string",
            "enum": [
              "none",
              "punctuationPairs"
            ],
            "default": "punctuationPairs",
            "enumItemLabels": [
              "%jpnov.layout.autoTcy.none.label%",
              "%jpnov.layout.autoTcy.punctuationPairs.label%"
            ],
            "enumDescriptions": [
              "%jpnov.layout.autoTcy.none.description%",
              "%jpnov.layout.autoTcy.punctuationPairs.description%"
            ],
            "order": 4,
            "markdownDescription": "%jpnov.layout.autoTcy.description%"
          },
          "jpnov.layout.preview.lineNumbers": {
            "type": "boolean",
            "default": true,
            "order": 5,
            "markdownDescription": "%jpnov.layout.preview.lineNumbers.description%"
          },
          "jpnov.layout.preview.edgeLine": {
            "type": "string",
            "enum": [
              "none",
              "text",
              "red"
            ],
            "default": "none",
            "enumItemLabels": [
              "%jpnov.layout.preview.edgeLine.none.label%",
              "%jpnov.layout.preview.edgeLine.text.label%",
              "%jpnov.layout.preview.edgeLine.red.label%"
            ],
            "enumDescriptions": [
              "%jpnov.layout.preview.edgeLine.none.description%",
              "%jpnov.layout.preview.edgeLine.text.description%",
              "%jpnov.layout.preview.edgeLine.red.description%"
            ],
            "order": 6,
            "markdownDescription": "%jpnov.layout.preview.edgeLine.description%"
          },
          "jpnov.layout.html.lineNumbers": {
            "type": "boolean",
            "default": false,
            "order": 7,
            "markdownDescription": "%jpnov.layout.html.lineNumbers.description%"
          },
          "jpnov.layout.html.edgeLine": {
            "type": "string",
            "enum": [
              "none",
              "text",
              "red"
            ],
            "default": "none",
            "enumItemLabels": [
              "%jpnov.layout.html.edgeLine.none.label%",
              "%jpnov.layout.html.edgeLine.text.label%",
              "%jpnov.layout.html.edgeLine.red.label%"
            ],
            "enumDescriptions": [
              "%jpnov.layout.html.edgeLine.none.description%",
              "%jpnov.layout.html.edgeLine.text.description%",
              "%jpnov.layout.html.edgeLine.red.description%"
            ],
            "order": 8,
            "markdownDescription": "%jpnov.layout.html.edgeLine.description%"
          },
          "jpnov.layout.txt.encoding": {
            "type": "string",
            "enum": [
              "shiftJis",
              "utf8",
              "utf8Bom"
            ],
            "default": "shiftJis",
            "enumItemLabels": [
              "%jpnov.layout.txt.encoding.shiftJis.label%",
              "%jpnov.layout.txt.encoding.utf8.label%",
              "%jpnov.layout.txt.encoding.utf8Bom.label%"
            ],
            "enumDescriptions": [
              "%jpnov.layout.txt.encoding.shiftJis.description%",
              "%jpnov.layout.txt.encoding.utf8.description%",
              "%jpnov.layout.txt.encoding.utf8Bom.description%"
            ],
            "order": 9,
            "markdownDescription": "%jpnov.layout.txt.encoding.description%"
          },
          "jpnov.layout.outDir": {
            "type": "string",
            "default": "dist",
            "scope": "resource",
            "order": 10,
            "markdownDescription": "%jpnov.layout.outDir.description%"
          },
          "jpnov.layout.browserPath": {
            "type": "string",
            "default": "",
            "scope": "machine-overridable",
            "order": 11,
            "markdownDescription": "%jpnov.layout.browserPath.description%"
          }
        }
      },
      {
        "title": "%jpnov.lint.title%",
        "order": 2,
        "properties": {
          "jpnov.lint.common.sentenceLength": {
            "type": [
              "integer",
              "null"
            ],
            "default": null,
            "minimum": 1,
            "maximum": 1000,
            "order": 1,
            "markdownDescription": "%jpnov.lint.common.sentenceLength.description%"
          },
          "jpnov.lint.common.maxTen": {
            "type": [
              "integer",
              "null"
            ],
            "default": null,
            "minimum": 1,
            "maximum": 20,
            "order": 2,
            "markdownDescription": "%jpnov.lint.common.maxTen.description%"
          },
          "jpnov.lint.common.maxKanjiRun": {
            "type": [
              "integer",
              "null"
            ],
            "default": null,
            "minimum": 1,
            "maximum": 20,
            "order": 3,
            "markdownDescription": "%jpnov.lint.common.maxKanjiRun.description%"
          },
          "jpnov.lint.common.dash": {
            "type": "string",
            "enum": [
              "emDash",
              "horizontalBar",
              "boxDrawing",
              "off"
            ],
            "default": "horizontalBar",
            "enumItemLabels": [
              "%jpnov.lint.common.dash.emDash.label%",
              "%jpnov.lint.common.dash.horizontalBar.label%",
              "%jpnov.lint.common.dash.boxDrawing.label%",
              "%jpnov.lint.common.dash.off.label%"
            ],
            "enumDescriptions": [
              "%jpnov.lint.common.dash.emDash.description%",
              "%jpnov.lint.common.dash.horizontalBar.description%",
              "%jpnov.lint.common.dash.boxDrawing.description%",
              "%jpnov.lint.common.dash.off.description%"
            ],
            "order": 4,
            "markdownDescription": "%jpnov.lint.common.dash.description%"
          },
          "jpnov.lint.common.noUnmatchedPair": {
            "type": "boolean",
            "default": false,
            "order": 5,
            "markdownDescription": "%jpnov.lint.common.noUnmatchedPair.description%"
          },
          "jpnov.lint.common.noHankakuKana": {
            "type": "boolean",
            "default": true,
            "order": 6,
            "markdownDescription": "%jpnov.lint.common.noHankakuKana.description%"
          },
          "jpnov.lint.common.noNfd": {
            "type": "boolean",
            "default": true,
            "order": 7,
            "markdownDescription": "%jpnov.lint.common.noNfd.description%"
          },
          "jpnov.lint.common.noZeroWidth": {
            "type": "boolean",
            "default": true,
            "order": 8,
            "markdownDescription": "%jpnov.lint.common.noZeroWidth.description%"
          },
          "jpnov.lint.common.noControlChar": {
            "type": "boolean",
            "default": true,
            "order": 9,
            "markdownDescription": "%jpnov.lint.common.noControlChar.description%"
          },
          "jpnov.lint.common.shiftJisSafe": {
            "type": "boolean",
            "default": true,
            "order": 10,
            "markdownDescription": "%jpnov.lint.common.shiftJisSafe.description%"
          },
          "jpnov.lint.common.jaNoSpaceBetweenFullWidth": {
            "type": "boolean",
            "default": false,
            "order": 11,
            "markdownDescription": "%jpnov.lint.common.jaNoSpaceBetweenFullWidth.description%"
          },
          "jpnov.lint.common.jaUnnaturalAlphabet": {
            "type": "boolean",
            "default": false,
            "order": 12,
            "markdownDescription": "%jpnov.lint.common.jaUnnaturalAlphabet.description%"
          },
          "jpnov.lint.common.minusPosition": {
            "type": "boolean",
            "default": false,
            "order": 13,
            "markdownDescription": "%jpnov.lint.common.minusPosition.description%"
          },
          "jpnov.lint.narration.generalNovelStyle": {
            "type": "boolean",
            "default": false,
            "order": 14,
            "markdownDescription": "%jpnov.lint.narration.generalNovelStyle.description%"
          },
          "jpnov.lint.narration.jaNoMixedPeriod": {
            "type": "boolean",
            "default": false,
            "order": 15,
            "markdownDescription": "%jpnov.lint.narration.jaNoMixedPeriod.description%"
          },
          "jpnov.lint.ruby.kana": {
            "type": "string",
            "enum": [
              "off",
              "hiragana",
              "katakana"
            ],
            "default": "off",
            "enumItemLabels": [
              "%jpnov.lint.ruby.kana.off.label%",
              "%jpnov.lint.ruby.kana.hiragana.label%",
              "%jpnov.lint.ruby.kana.katakana.label%"
            ],
            "enumDescriptions": [
              "%jpnov.lint.ruby.kana.off.description%",
              "%jpnov.lint.ruby.kana.hiragana.description%",
              "%jpnov.lint.ruby.kana.katakana.description%"
            ],
            "order": 16,
            "markdownDescription": "%jpnov.lint.ruby.kana.description%"
          }
        }
      },
      {
        "title": "%jpnov.editor.title%",
        "order": 3,
        "properties": {
          "jpnov.editor.autoIndent": {
            "type": "boolean",
            "default": true,
            "order": 1,
            "markdownDescription": "%jpnov.editor.autoIndent.description%"
          },
          "jpnov.editor.highlight.characters": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "scope": "resource",
            "order": 2,
            "markdownDescription": "%jpnov.editor.highlight.characters.description%"
          },
          "jpnov.editor.highlight.keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "scope": "resource",
            "order": 3,
            "markdownDescription": "%jpnov.editor.highlight.keywords.description%"
          },
          "jpnov.editor.updateRefsOnFileMove": {
            "type": "string",
            "enum": [
              "prompt",
              "always",
              "never"
            ],
            "default": "prompt",
            "enumItemLabels": [
              "%jpnov.editor.updateRefsOnFileMove.prompt.label%",
              "%jpnov.editor.updateRefsOnFileMove.always.label%",
              "%jpnov.editor.updateRefsOnFileMove.never.label%"
            ],
            "enumDescriptions": [
              "%jpnov.editor.updateRefsOnFileMove.prompt.description%",
              "%jpnov.editor.updateRefsOnFileMove.always.description%",
              "%jpnov.editor.updateRefsOnFileMove.never.description%"
            ],
            "order": 4,
            "markdownDescription": "%jpnov.editor.updateRefsOnFileMove.description%"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "jpbook.buildHtml",
        "category": "%command.category%",
        "title": "%command.books.buildHtml.title%",
        "icon": "$(globe)"
      },
      {
        "command": "jpbook.buildTxt",
        "category": "%command.category%",
        "title": "%command.books.buildTxt.title%",
        "icon": "$(file)"
      },
      {
        "command": "jpbook.buildPdf",
        "category": "%command.category%",
        "title": "%command.books.buildPdf.title%",
        "icon": "$(file-pdf)"
      },
      {
        "command": "jpbook.selectAll",
        "category": "%command.category%",
        "title": "%command.books.selectAll.title%",
        "icon": "$(check-all)"
      },
      {
        "command": "jpbook.deselectAll",
        "category": "%command.category%",
        "title": "%command.books.deselectAll.title%",
        "icon": "$(clear-all)"
      },
      {
        "command": "jpbook.refresh",
        "category": "%command.category%",
        "title": "%command.books.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "jpnov.openGuide",
        "category": "%command.category%",
        "title": "%command.openGuide.title%"
      },
      {
        "command": "jpbook.addChapters",
        "category": "%command.category%",
        "title": "%command.book.addChapters.title%",
        "icon": "$(add)"
      },
      {
        "command": "jpbook.removeChapter",
        "category": "%command.category%",
        "title": "%command.book.removeChapter.title%",
        "icon": "$(remove)"
      },
      {
        "command": "jpbook.moveChapterUp",
        "category": "%command.category%",
        "title": "%command.book.moveChapterUp.title%"
      },
      {
        "command": "jpbook.moveChapterDown",
        "category": "%command.category%",
        "title": "%command.book.moveChapterDown.title%"
      },
      {
        "command": "jpbook.editMeta",
        "category": "%command.category%",
        "title": "%command.book.editMeta.title%"
      },
      {
        "command": "jpnov.preview",
        "category": "%command.category%",
        "title": "%command.preview.title%"
      },
      {
        "command": "jpnov.previewToSide",
        "category": "%command.category%",
        "title": "%command.previewToSide.title%",
        "icon": "$(open-preview)"
      }
    ],
    "views": {
      "jpnov": [
        {
          "id": "jpnov.books",
          "name": "%view.books.name%",
          "icon": "$(book)",
          "when": "jpnov.active",
          "contextualTitle": "%view.books.contextualTitle%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "jpnov.books",
        "contents": "%viewsWelcome.books.content%",
        "when": "workspaceFolderCount != 0"
      },
      {
        "view": "jpnov.books",
        "contents": "%viewsWelcome.books.noFolder.content%",
        "when": "workspaceFolderCount == 0"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jpbook.buildHtml",
          "group": "navigation@1",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpbook.buildTxt",
          "group": "navigation@2",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpbook.buildPdf",
          "group": "navigation@3",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpbook.selectAll",
          "group": "navigation@4",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpbook.deselectAll",
          "group": "navigation@5",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpbook.refresh",
          "group": "navigation@6",
          "when": "view == jpnov.books"
        }
      ],
      "view/item/context": [
        {
          "command": "jpbook.addChapters",
          "group": "inline",
          "when": "view == jpnov.books && viewItem == jpnovBook"
        },
        {
          "command": "jpbook.removeChapter",
          "group": "inline",
          "when": "view == jpnov.books && viewItem == jpnovChapter"
        },
        {
          "command": "jpbook.moveChapterUp",
          "group": "1_move@1",
          "when": "view == jpnov.books && viewItem == jpnovChapter"
        },
        {
          "command": "jpbook.moveChapterDown",
          "group": "1_move@2",
          "when": "view == jpnov.books && viewItem == jpnovChapter"
        },
        {
          "command": "jpbook.removeChapter",
          "group": "9_remove",
          "when": "view == jpnov.books && viewItem == jpnovChapter"
        }
      ],
      "editor/title": [
        {
          "command": "jpnov.previewToSide",
          "group": "navigation",
          "when": "editorLangId == jpnov"
        }
      ],
      "commandPalette": [
        {
          "command": "jpnov.preview",
          "when": "editorLangId == jpnov"
        },
        {
          "command": "jpnov.previewToSide",
          "when": "editorLangId == jpnov"
        },
        {
          "command": "jpbook.buildHtml",
          "when": "false"
        },
        {
          "command": "jpbook.buildTxt",
          "when": "false"
        },
        {
          "command": "jpbook.buildPdf",
          "when": "false"
        },
        {
          "command": "jpbook.selectAll",
          "when": "false"
        },
        {
          "command": "jpbook.deselectAll",
          "when": "false"
        },
        {
          "command": "jpbook.refresh",
          "when": "false"
        },
        {
          "command": "jpbook.addChapters",
          "when": "false"
        },
        {
          "command": "jpbook.removeChapter",
          "when": "false"
        },
        {
          "command": "jpbook.moveChapterUp",
          "when": "false"
        },
        {
          "command": "jpbook.moveChapterDown",
          "when": "false"
        },
        {
          "command": "jpbook.editMeta",
          "when": "false"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jpnov",
          "title": "%view.container.title%",
          "icon": "resources/book.svg"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "jpnov.gettingStarted",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "featuredFor": [
          "**/*.jpnov",
          "**/*.jpbook"
        ],
        "steps": [
          {
            "id": "chapter",
            "title": "%walkthrough.chapter.title%",
            "description": "%walkthrough.chapter.description%",
            "media": {
              "markdown": "media/walkthrough/chapter.md"
            },
            "completionEvents": [
              "onCommand:workbench.action.files.newUntitledFile"
            ]
          },
          {
            "id": "preview",
            "title": "%walkthrough.preview.title%",
            "description": "%walkthrough.preview.description%",
            "media": {
              "markdown": "media/walkthrough/preview.md"
            },
            "completionEvents": [
              "onCommand:jpnov.previewToSide"
            ]
          },
          {
            "id": "build",
            "title": "%walkthrough.build.title%",
            "description": "%walkthrough.build.description%",
            "media": {
              "markdown": "media/walkthrough/build.md"
            },
            "completionEvents": [
              "onCommand:jpbook.buildHtml",
              "onCommand:jpbook.buildTxt",
              "onCommand:jpbook.buildPdf"
            ]
          },
          {
            "id": "highlight",
            "title": "%walkthrough.highlight.title%",
            "description": "%walkthrough.highlight.description%",
            "media": {
              "markdown": "media/walkthrough/highlight.md"
            },
            "completionEvents": [
              "onSettingChanged:jpnov.editor.highlight.characters",
              "onSettingChanged:jpnov.editor.highlight.keywords",
              "onSettingChanged:jpnov.lint.narration.generalNovelStyle"
            ]
          }
        ]
      }
    ]
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "gen:styles": "node scripts/gen-styles.ts",
    "build": "node esbuild.config.js --production",
    "build:dev": "node esbuild.config.js",
    "watch:esbuild": "node esbuild.config.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "watch": "npm run watch:tsc & npm run watch:esbuild & wait",
    "pretest": "npm run type-check",
