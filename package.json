{
  "name": "jpnov",
  "displayName": "Japanese Novel",
  "version": "0.0.2",
  "description": "A plugin for Visual Studio Code for formatting, previewing, and generating ebooks of Japanese novels annotated by Aozora Bunko",
  "keywords": [
    "plugin",
    "novel",
    "japanese"
  ],
  "homepage": "https://github.com/asagirimihatsu/vscode-jpnov#readme",
  "bugs": {
    "url": "https://github.com/asagirimihatsu/vscode-jpnov/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asagirimihatsu/vscode-jpnov.git"
  },
  "license": "MIT",
  "author": "Mihatsu Asagiri",
  "type": "module",
  "main": "dist/client/extension.js",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.129.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onWebviewPanel:jpnov.preview",
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "novel-jp",
        "aliases": [
          "%language.novelJp.alias%"
        ],
        "extensions": [
          ".jpnov"
        ],
        "configuration": "./jpnov.language-configuration.json"
      },
      {
        "id": "novel-jp-book",
        "aliases": [
          "%language.novelJpBook.alias%"
        ],
        "extensions": [
          ".jpbook"
        ],
        "configuration": "./jpbook.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "novel-jp",
        "scopeName": "text.novel-jp",
        "path": "./syntaxes/novel-jp.tmLanguage.json"
      },
      {
        "language": "novel-jp-book",
        "scopeName": "text.novel-jp-book",
        "path": "./syntaxes/jpbook.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[novel-jp]": {
        "editor.wordBasedSuggestions": "off",
        "editor.semanticHighlighting.enabled": true,
        "editor.unicodeHighlight.nonBasicASCII": false,
        "editor.unicodeHighlight.allowedCharacters": {
          "　": true,
          "！": true,
          "？": true,
          "（": true,
          "）": true,
          "：": true,
          "；": true,
          "，": true,
          "．": true,
          "｜": true,
          "＃": true,
          "［": true,
          "］": true,
          "〔": true,
          "〕": true,
          "〜": true
        }
      },
      "[novel-jp-book]": {
        "editor.wordBasedSuggestions": "off",
        "editor.unicodeHighlight.nonBasicASCII": false,
        "editor.unicodeHighlight.allowedCharacters": {
          "　": true,
          "！": true,
          "？": true,
          "（": true,
          "）": true,
          "：": true,
          "；": true,
          "，": true,
          "．": true,
          "｜": true,
          "＃": true,
          "［": true,
          "］": true,
          "〔": true,
          "〕": true,
          "〜": true
        }
      },
      "github.copilot.enable": {
        "novel-jp": false,
        "novel-jp-book": false
      }
    },
    "configuration": [
      {
        "title": "%jpnov.layout.title%",
        "order": 1,
        "properties": {
          "jpnov.layout.charsPerLine": {
            "type": "integer",
            "default": 40,
            "minimum": 16,
            "maximum": 64,
            "markdownDescription": "%jpnov.layout.charsPerLine.description%"
          },
          "jpnov.layout.linesPerPage": {
            "type": "integer",
            "default": 34,
            "minimum": 16,
            "maximum": 64,
            "markdownDescription": "%jpnov.layout.linesPerPage.description%"
          },
          "jpnov.layout.kinsoku": {
            "type": "string",
            "enum": [
              "none",
              "normal",
              "strict"
            ],
            "default": "normal",
            "enumItemLabels": [
              "%jpnov.layout.kinsoku.none.label%",
              "%jpnov.layout.kinsoku.normal.label%",
              "%jpnov.layout.kinsoku.strict.label%"
            ],
            "enumDescriptions": [
              "%jpnov.layout.kinsoku.none.description%",
              "%jpnov.layout.kinsoku.normal.description%",
              "%jpnov.layout.kinsoku.strict.description%"
            ],
            "markdownDescription": "%jpnov.layout.kinsoku.description%"
          },
          "jpnov.layout.autoTateChuYoko": {
            "type": "string",
            "enum": [
              "none",
              "punctuationPairs"
            ],
            "default": "punctuationPairs",
            "enumItemLabels": [
              "%jpnov.layout.autoTateChuYoko.none.label%",
              "%jpnov.layout.autoTateChuYoko.punctuationPairs.label%"
            ],
            "enumDescriptions": [
              "%jpnov.layout.autoTateChuYoko.none.description%",
              "%jpnov.layout.autoTateChuYoko.punctuationPairs.description%"
            ],
            "markdownDescription": "%jpnov.layout.autoTateChuYoko.description%"
          }
        }
      },
      {
        "title": "%jpnov.html.title%",
        "order": 2,
        "properties": {
          "jpnov.html.lineNumbers": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "%jpnov.html.lineNumbers.description%"
          },
          "jpnov.html.edgeLine": {
            "type": "string",
            "enum": [
              "none",
              "text",
              "red"
            ],
            "default": "none",
            "enumItemLabels": [
              "%jpnov.html.edgeLine.none.label%",
              "%jpnov.html.edgeLine.text.label%",
              "%jpnov.html.edgeLine.red.label%"
            ],
            "enumDescriptions": [
              "%jpnov.html.edgeLine.none.description%",
              "%jpnov.html.edgeLine.text.description%",
              "%jpnov.html.edgeLine.red.description%"
            ],
            "markdownDescription": "%jpnov.html.edgeLine.description%"
          }
        }
      },
      {
        "title": "%jpnov.preview.title%",
        "order": 3,
        "properties": {
          "jpnov.preview.lineNumbers": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%jpnov.preview.lineNumbers.description%"
          },
          "jpnov.preview.edgeLine": {
            "type": "string",
            "enum": [
              "none",
              "text",
              "red"
            ],
            "default": "none",
            "enumItemLabels": [
              "%jpnov.preview.edgeLine.none.label%",
              "%jpnov.preview.edgeLine.text.label%",
              "%jpnov.preview.edgeLine.red.label%"
            ],
            "enumDescriptions": [
              "%jpnov.preview.edgeLine.none.description%",
              "%jpnov.preview.edgeLine.text.description%",
              "%jpnov.preview.edgeLine.red.description%"
            ],
            "markdownDescription": "%jpnov.preview.edgeLine.description%"
          }
        }
      },
      {
        "title": "%jpnov.lint.title%",
        "order": 4,
        "properties": {
          "jpnov.lint.common.sentenceLength": {
            "type": [
              "integer",
              "null"
            ],
            "default": null,
            "minimum": 1,
            "maximum": 1000,
            "order": 1,
            "markdownDescription": "%jpnov.lint.common.sentenceLength.description%"
          },
          "jpnov.lint.common.maxTen": {
            "type": [
              "integer",
              "null"
            ],
            "default": null,
            "minimum": 1,
            "maximum": 20,
            "order": 2,
            "markdownDescription": "%jpnov.lint.common.maxTen.description%"
          },
          "jpnov.lint.common.maxKanjiRun": {
            "type": [
              "integer",
              "null"
            ],
            "default": null,
            "minimum": 1,
            "maximum": 20,
            "order": 3,
            "markdownDescription": "%jpnov.lint.common.maxKanjiRun.description%"
          },
          "jpnov.lint.common.noEmDash": {
            "type": "boolean",
            "default": false,
            "order": 4,
            "markdownDescription": "%jpnov.lint.common.noEmDash.description%"
          },
          "jpnov.lint.common.noUnmatchedPair": {
            "type": "boolean",
            "default": false,
            "order": 5,
            "markdownDescription": "%jpnov.lint.common.noUnmatchedPair.description%"
          },
          "jpnov.lint.common.noHankakuKana": {
            "type": "boolean",
            "default": true,
            "order": 6,
            "markdownDescription": "%jpnov.lint.common.noHankakuKana.description%"
          },
          "jpnov.lint.common.noNfd": {
            "type": "boolean",
            "default": true,
            "order": 7,
            "markdownDescription": "%jpnov.lint.common.noNfd.description%"
          },
          "jpnov.lint.common.noZeroWidth": {
            "type": "boolean",
            "default": true,
            "order": 8,
            "markdownDescription": "%jpnov.lint.common.noZeroWidth.description%"
          },
          "jpnov.lint.common.noControlChar": {
            "type": "boolean",
            "default": true,
            "order": 9,
            "markdownDescription": "%jpnov.lint.common.noControlChar.description%"
          },
          "jpnov.lint.common.jaNoSpaceBetweenFullWidth": {
            "type": "boolean",
            "default": false,
            "order": 10,
            "markdownDescription": "%jpnov.lint.common.jaNoSpaceBetweenFullWidth.description%"
          },
          "jpnov.lint.common.jaUnnaturalAlphabet": {
            "type": "boolean",
            "default": false,
            "order": 11,
            "markdownDescription": "%jpnov.lint.common.jaUnnaturalAlphabet.description%"
          },
          "jpnov.lint.common.minusPosition": {
            "type": "boolean",
            "default": false,
            "order": 12,
            "markdownDescription": "%jpnov.lint.common.minusPosition.description%"
          },
          "jpnov.lint.narration.generalNovelStyle": {
            "type": "boolean",
            "default": false,
            "order": 13,
            "markdownDescription": "%jpnov.lint.narration.generalNovelStyle.description%"
          },
          "jpnov.lint.narration.jaNoMixedPeriod": {
            "type": "boolean",
            "default": false,
            "order": 14,
            "markdownDescription": "%jpnov.lint.narration.jaNoMixedPeriod.description%"
          },
          "jpnov.lint.ruby.kana": {
            "type": "string",
            "enum": [
              "off",
              "hiragana",
              "katakana"
            ],
            "default": "off",
            "enumItemLabels": [
              "%jpnov.lint.ruby.kana.off.label%",
              "%jpnov.lint.ruby.kana.hiragana.label%",
              "%jpnov.lint.ruby.kana.katakana.label%"
            ],
            "enumDescriptions": [
              "%jpnov.lint.ruby.kana.off.description%",
              "%jpnov.lint.ruby.kana.hiragana.description%",
              "%jpnov.lint.ruby.kana.katakana.description%"
            ],
            "order": 15,
            "markdownDescription": "%jpnov.lint.ruby.kana.description%"
          }
        }
      },
      {
        "title": "%jpnov.project.title%",
        "order": 5,
        "properties": {
          "jpnov.project.outDir": {
            "type": "string",
            "default": "dist",
            "scope": "resource",
            "markdownDescription": "%jpnov.project.outDir.description%"
          }
        }
      },
      {
        "title": "%jpnov.build.title%",
        "order": 6,
        "properties": {
          "jpnov.build.browserPath": {
            "type": "string",
            "default": "",
            "scope": "machine-overridable",
            "markdownDescription": "%jpnov.build.browserPath.description%"
          }
        }
      },
      {
        "title": "%jpnov.highlight.title%",
        "order": 7,
        "properties": {
          "jpnov.highlight.characters": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "scope": "resource",
            "markdownDescription": "%jpnov.highlight.characters.description%"
          },
          "jpnov.highlight.keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "scope": "resource",
            "markdownDescription": "%jpnov.highlight.keywords.description%"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "jpnov.books.buildHtml",
        "category": "%command.category%",
        "title": "%command.books.buildHtml.title%",
        "icon": "$(globe)"
      },
      {
        "command": "jpnov.books.buildTxt",
        "category": "%command.category%",
        "title": "%command.books.buildTxt.title%",
        "icon": "$(file)"
      },
      {
        "command": "jpnov.books.buildPdf",
        "category": "%command.category%",
        "title": "%command.books.buildPdf.title%",
        "icon": "$(file-pdf)"
      },
      {
        "command": "jpnov.books.selectAll",
        "category": "%command.category%",
        "title": "%command.books.selectAll.title%",
        "icon": "$(check-all)"
      },
      {
        "command": "jpnov.books.deselectAll",
        "category": "%command.category%",
        "title": "%command.books.deselectAll.title%",
        "icon": "$(clear-all)"
      },
      {
        "command": "jpnov.books.refresh",
        "category": "%command.category%",
        "title": "%command.books.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "jpnov.preview",
        "category": "%command.category%",
        "title": "%command.preview.title%"
      },
      {
        "command": "jpnov.previewToSide",
        "category": "%command.category%",
        "title": "%command.previewToSide.title%",
        "icon": "$(open-preview)"
      }
    ],
    "views": {
      "jpnov": [
        {
          "id": "jpnov.books",
          "name": "%view.books.name%",
          "icon": "$(book)",
          "when": "jpnov.active",
          "contextualTitle": "%view.books.contextualTitle%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "jpnov.books",
        "contents": "%viewsWelcome.books.content%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jpnov.books.buildHtml",
          "group": "navigation@1",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpnov.books.buildTxt",
          "group": "navigation@2",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpnov.books.buildPdf",
          "group": "navigation@3",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpnov.books.selectAll",
          "group": "navigation@4",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpnov.books.deselectAll",
          "group": "navigation@5",
          "when": "view == jpnov.books"
        },
        {
          "command": "jpnov.books.refresh",
          "group": "navigation@6",
          "when": "view == jpnov.books"
        }
      ],
      "editor/title": [
        {
          "command": "jpnov.previewToSide",
          "group": "navigation",
          "when": "editorLangId == novel-jp"
        }
      ],
      "commandPalette": [
        {
          "command": "jpnov.preview",
          "when": "editorLangId == novel-jp"
        },
        {
          "command": "jpnov.previewToSide",
          "when": "editorLangId == novel-jp"
        },
        {
          "command": "jpnov.books.buildHtml",
          "when": "false"
        },
        {
          "command": "jpnov.books.buildTxt",
          "when": "false"
        },
        {
          "command": "jpnov.books.buildPdf",
          "when": "false"
        },
        {
          "command": "jpnov.books.selectAll",
          "when": "false"
        },
        {
          "command": "jpnov.books.deselectAll",
          "when": "false"
        },
        {
          "command": "jpnov.books.refresh",
          "when": "false"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jpnov",
          "title": "%view.container.title%",
          "icon": "resources/book.svg"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "jpnov.gettingStarted",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "featuredFor": [
          "**/*.jpnov",
          "**/*.jpbook"
        ],
        "steps": [
          {
            "id": "chapter",
            "title": "%walkthrough.chapter.title%",
            "description": "%walkthrough.chapter.description%",
            "media": {
              "markdown": "media/walkthrough/chapter.md"
            },
            "completionEvents": [
              "onCommand:workbench.action.files.newUntitledFile"
            ]
          },
          {
            "id": "preview",
            "title": "%walkthrough.preview.title%",
            "description": "%walkthrough.preview.description%",
            "media": {
              "markdown": "media/walkthrough/preview.md"
            },
            "completionEvents": [
              "onCommand:jpnov.previewToSide"
            ]
          },
          {
            "id": "build",
            "title": "%walkthrough.build.title%",
            "description": "%walkthrough.build.description%",
            "media": {
              "markdown": "media/walkthrough/build.md"
            },
            "completionEvents": [
              "onCommand:jpnov.books.buildHtml",
              "onCommand:jpnov.books.buildTxt",
              "onCommand:jpnov.books.buildPdf"
            ]
          },
          {
            "id": "highlight",
            "title": "%walkthrough.highlight.title%",
            "description": "%walkthrough.highlight.description%",
            "media": {
              "markdown": "media/walkthrough/highlight.md"
            },
            "completionEvents": [
              "onSettingChanged:jpnov.highlight.characters",
              "onSettingChanged:jpnov.highlight.keywords",
              "onSettingChanged:jpnov.lint.narration.generalNovelStyle"
            ]
          }
        ]
      }
    ]
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "gen:styles": "node scripts/gen-styles.ts",
    "build": "node esbuild.config.js --production",
    "build:dev": "node esbuild.config.js",
    "watch:esbuild": "node esbuild.config.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "watch": "npm run watch:tsc & npm run watch:esbuild & wait",
    "pretest": "npm run type-check",
    "test": "node --test --experimental-test-module-mocks \"test/shared/**/*.test.ts\" \"test/server/highlight/**/*.test.ts\" \"test/server/lint/**/*.test.ts\" \"test/client/browser.test.ts\"",
    "vscode:prepublish": "npm run type-check && npm run lint && npm run build",
    "package": "vsce package"
  },
  "dependencies": {
    "@textlint-rule/textlint-rule-no-invalid-control-character": "^3.0.0",
    "@textlint-rule/textlint-rule-no-unmatched-pair": "^2.0.4",
    "@textlint/kernel": "^15.7.1",
    "@textlint/textlint-plugin-text": "^15.7.1",
    "textlint-rule-general-novel-style-ja": "^1.3.0",
    "textlint-rule-ja-no-mixed-period": "^3.0.2",
    "textlint-rule-ja-unnatural-alphabet": "^2.0.1",
    "textlint-rule-max-kanji-continuous-len": "^1.1.1",
    "textlint-rule-no-hankaku-kana": "^2.0.1",
    "textlint-rule-no-nfd": "^2.0.2",
    "textlint-rule-no-zero-width-spaces": "^1.0.1",
    "textlint-rule-sentence-length": "^5.2.1",
    "vscode-languageclient": "^10.1.0",
    "vscode-languageserver": "^10.1.0",
    "vscode-languageserver-textdocument": "^1.0.13"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
